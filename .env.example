MEDUSA_ADMIN_ONBOARDING_TYPE=
STORE_CORS=
ADMIN_CORS=
AUTH_CORS=
REDIS_URL=
JWT_SECRET=
COOKIE_SECRET=
DATABASE_URL=
MEDUSA_ADMIN_ONBOARDING_NEXTJS_DIRECTORY=
# Stripe — paste your keys from https://dashboard.stripe.com/apikeys
# Use test keys for development (sk_test_... / pk_test_...)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Mailgun SMTP (reused from becauseyou)
MAIL_MAILER=
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Public origin for the Medusa admin / API. Used by the local file
# provider when persisting uploaded image URLs. MUST be reachable from
# the admin browser; setting this to localhost makes uploads render as
# broken images even though the upload API returns 200.
# Example: https://admin.example.com  (or http://194.233.77.181:9000 for IP-only dev)
MEDUSA_BACKEND_URL=

# Storefront cache invalidation webhook — lets admin saves call back into
# the storefront and revalidate ISR tags immediately (zero-lag propagation).
# REVALIDATE_SECRET must match what's in storefront/.env.local.
# STOREFRONT_URL points at the running Next.js process (defaults 127.0.0.1:3003).
REVALIDATE_SECRET=
STOREFRONT_URL=
